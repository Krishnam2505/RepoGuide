# The port on which the FastAPI server will run
PORT=8000

# Your Google Gemini API Key for Embeddings and Chat Generation
GEMINI_API_KEY=

# The directory where ChromaDB will persist its vector store data
CHROMA_PERSIST_DIR=./chroma_store

# The local directory where GitHub repositories will be cloned
CLONE_DIR=./cloned_repos

# Skips huge generated/binary files so we don't waste embedding calls on them
MAX_FILE_SIZE_KB=500
